# CORS — gốc (origin) mà trình duyệt mở SPA, cách nhau bởi dấu phẩy.
# Dev Angular: http://localhost:4200,http://127.0.0.1:4200
# Docker compose (README deploy): http://localhost:8080,http://127.0.0.1:8080
# Production: https://ten-mien-cua-ban.com
# CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
# Khi có ảnh/ghi âm: nếu đặt biến này, backend dùng model này thay vì OPENROUTER_MODEL (nên chọn model multimodal).
# Model :free dễ bị 429 từ phía nhà cung cấp — thử model khác hoặc dùng key có credit.
OPENROUTER_MULTIMODAL_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Gửi ảnh/âm thanh thường chậm hơn; có thể tăng ví dụ 60
OPENROUTER_TIMEOUT_S=20

TRIAGE_EXAMPLES_PATH=
TRIAGE_EXAMPLES_LIMIT=6

# Optional: override path to triage_rules.json (defaults to backend/app/data/triage_rules.json)
TRIAGE_RULES_PATH=

# --- Appointment booking / email (optional for demo) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Public URL used inside email links (doctor confirm/decline)
PUBLIC_BASE_URL=http://localhost:8000

# Secret used to sign confirm/decline tokens
APPOINTMENT_TOKEN_SECRET=dev-secret-change-me

