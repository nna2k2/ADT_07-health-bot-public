
      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 16px;
        gap: 12px;
      }

      .topbar__back {
        width: 32px;
        height: 32px;
        display: grid;
        place-items: center;
        border-radius: 12px;
        color: var(--text);
      }

      .topbar__back svg {
        width: 22px;
        height: 22px;
        stroke: currentColor;
        fill: none;
        stroke-width: 2.25;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .topbar__title-pill {
        margin-left: auto;
        background: var(--white);
        border-radius: 12px;
        padding: 4px 16px;
        box-shadow: var(--shadow-card);
      }

      .topbar__title {
        font-size: 13.9px;
        font-weight: 600;
        line-height: 20px;
        color: var(--text);
        white-space: nowrap;
      }
    