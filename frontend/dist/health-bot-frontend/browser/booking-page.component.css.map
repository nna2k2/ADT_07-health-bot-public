
      .content {
        min-height: 100%;
        background: #f4f4f4;
        padding-top: 8px;
        padding-bottom: 24px;
      }

      .doctor {
        background: #fff;
        border-radius: 24px;
        padding: 12px;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.1), 0px 1px 2px -1px rgba(0, 0, 0, 0.1);
        margin-top: 10px;
      }

      .avatar {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        object-fit: contain;
        background: #f4f4f4;
      }

      .meta {
        display: grid;
        gap: 4px;
        min-width: 0;
      }

      .name {
        font-size: 14px;
        font-weight: 700;
        line-height: 16px;
        color: #2a2a37;
      }

      .spec {
        font-size: 13px;
        line-height: 16px;
        color: #8d90a1;
      }

      .form {
        display: grid;
        gap: 12px;
        margin-top: 12px;
      }

      .card {
        background: #fff;
        border-radius: 16px;
        padding: 16px;
        box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.1), 0px 1px 2px -1px rgba(0, 0, 0, 0.1);
      }

      .row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .row__label {
        font-size: 14px;
        line-height: 20px;
        color: #171717;
      }

      .date {
        border: none;
        outline: none;
        font-size: 14px;
        line-height: 20px;
        color: #737373;
        background: transparent;
      }

      .input {
        width: 100%;
        border: none;
        outline: none;
        font-size: 14px;
        line-height: 20px;
        color: #171717;
      }

      .slots {
        background: #fff;
        border-radius: 24px;
        padding: 16px;
        box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.1), 0px 1px 2px -1px rgba(0, 0, 0, 0.1);
      }

      .slots__title {
        font-size: 14px;
        font-weight: 700;
        line-height: 20px;
        color: #171717;
        margin-bottom: 10px;
      }

      .slots__grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 8px;
      }

      .slot {
        border: 1px solid rgba(0, 0, 0, 0.08);
        background: #f6f6f6;
        border-radius: 14px;
        padding: 10px 8px;
        font-size: 12px;
        line-height: 16px;
        cursor: pointer;
        color: #171717;
      }

      .slot--active {
        background: rgba(0, 166, 62, 0.14);
        border-color: rgba(0, 166, 62, 0.35);
        box-shadow: 0 0 0 2px rgba(0, 166, 62, 0.12);
      }

      .btn {
        height: 52px;
        border: none;
        border-radius: 999px;
        background: #00a63e;
        color: #fff;
        font-size: 14px;
        font-weight: 600;
        line-height: 20px;
        cursor: pointer;
      }

      .btn:disabled {
        opacity: 0.75;
        cursor: not-allowed;
      }

      .hint {
        font-size: 12px;
        line-height: 16px;
      }

      .empty {
        padding-top: 10px;
        font-size: 12px;
        color: #737373;
      }
    