
      .content {
        padding-bottom: 78px;
      }

      .card {
        background: var(--white);
        border-radius: 28px;
        padding: 20px;
        box-shadow: var(--shadow-card);
        display: grid;
        justify-items: center;
      }

      .avatar {
        width: 80px;
        height: 80px;
        border-radius: 999px;
        margin-top: 4px;
      }

      .name {
        margin-top: 12px;
        font-size: 18px;
        font-weight: 600;
        line-height: 28px;
        color: var(--text);
      }

      .sub {
        margin-top: 4px;
        font-size: 12px;
        line-height: 16px;
        text-align: center;
      }

      .facts {
        width: 100%;
        display: grid;
        gap: 12px;
        margin-top: 18px;
      }

      .fact {
        width: 100%;
        background: #f4f4f4;
        border-radius: 16px;
        padding: 12px 16px;
        font-size: 14px;
        line-height: 20px;
        color: var(--text);
      }

      .btn {
        width: 100%;
        height: 52px;
        border: none;
        border-radius: 999px;
        background: var(--primary-2);
        color: #fff;
        font-size: 14px;
        font-weight: 600;
        line-height: 20px;
        margin-top: 14px;
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(0, 166, 62, 0.28);
      }

      .btn:disabled {
        opacity: 0.75;
        cursor: not-allowed;
        box-shadow: none;
      }

      .btn--danger {
        margin-top: 10px;
        background: #fff1f2;
        color: #b91c1c;
        box-shadow: none;
        border: 1px solid rgba(185, 28, 28, 0.22);
      }

      .err {
        color: #ec003f;
        font-size: 13px;
        margin-top: 10px;
      }
    