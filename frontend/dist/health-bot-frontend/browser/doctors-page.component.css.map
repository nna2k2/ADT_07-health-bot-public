
      .content {
        min-height: 100%;
        background: #f4f4f4;
        padding-top: 8px;
        padding-bottom: 24px;
      }

      .list {
        display: grid;
        gap: 12px;
        padding-top: 12px;
      }

      .empty {
        padding: 16px;
        color: #737373;
        font-size: 13px;
      }

      .card {
        background: #fff;
        border-radius: 24px;
        padding: 12px;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.1), 0px 1px 2px -1px rgba(0, 0, 0, 0.1);
      }

      .avatar {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        object-fit: contain;
        background: #f4f4f4;
        flex-shrink: 0;
      }

      .meta {
        flex: 1;
        min-width: 0;
        display: grid;
        gap: 4px;
      }

      .name {
        font-size: 14px;
        font-weight: 700;
        line-height: 16px;
        color: #2a2a37;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .spec {
        font-size: 13px;
        line-height: 16px;
        color: #8d90a1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .chev {
        width: 24px;
        text-align: right;
        font-size: 22px;
        line-height: 22px;
        color: #8d90a1;
      }
    