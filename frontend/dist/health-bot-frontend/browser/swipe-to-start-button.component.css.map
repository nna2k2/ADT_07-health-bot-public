
      .swipe {
        position: relative;
        width: 100%;
        height: 62px;
        border-radius: 50px;
        background: var(--primary);
        overflow: hidden;
        user-select: none;
        touch-action: none;
      }

      .swipe__track {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        padding: 0 18px;
      }

      .swipe__label {
        font-size: 24px;
        font-weight: 500;
        line-height: 18px;
        color: #fff;
        text-transform: capitalize;
      }

      .swipe__thumb {
        position: absolute;
        left: 5px;
        top: 5px;
        width: 52px;
        height: 52px;
        border-radius: 999px;
        background: #fff;
        display: grid;
        place-items: center;
        will-change: transform;
        transition: transform 240ms cubic-bezier(0.2, 0.8, 0.2, 1);
        box-shadow: 0px 8px 22px rgba(0, 0, 0, 0.18);
      }

      .swipe__thumb.is-dragging {
        transition: none;
      }

      .swipe__thumb-inner {
        color: var(--primary);
        font-size: 28px;
        line-height: 1;
        transform: translateY(-1px);
      }

      .swipe.is-complete .swipe__thumb {
        transition: transform 260ms cubic-bezier(0.2, 0.8, 0.2, 1);
      }
    