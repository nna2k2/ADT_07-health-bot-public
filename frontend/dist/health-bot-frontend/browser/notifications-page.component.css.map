
      .content {
        min-height: 100%;
        background: #f4f4f4;
        padding-top: 8px;
        padding-bottom: 24px;
      }

      .topbar {
        display: grid;
        grid-template-columns: 40px 1fr 40px;
        align-items: center;
        padding: 8px 0 8px;
      }

      .back {
        width: 40px;
        height: 40px;
        border-radius: 999px;
        border: none;
        background: transparent;
        display: grid;
        place-items: center;
        cursor: pointer;
        color: #171717;
      }

      .back svg {
        width: 22px;
        height: 22px;
      }

      .title {
        font-size: 18px;
        font-weight: 600;
        line-height: 28px;
        color: #171717;
      }

      .spacer {
        width: 40px;
        height: 40px;
      }

      .list {
        display: grid;
        gap: 12px;
        padding: 12px 0 0;
      }

      .empty {
        padding: 16px;
        color: #737373;
        font-size: 13px;
      }

      .card {
        position: relative;
        background: #fff;
        border-radius: 24px;
        padding: 16px;
        box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.1), 0px 1px 2px -1px rgba(0, 0, 0, 0.1);
      }

      .card__title {
        font-size: 14px;
        font-weight: 600;
        line-height: 20px;
        color: #171717;
      }

      .card__desc {
        margin-top: 4px;
        font-size: 12px;
        font-weight: 400;
        line-height: 16px;
        color: #737373;
      }

      .card__time {
        margin-top: 8px;
        font-size: 11px;
        color: #737373;
        opacity: 0.8;
      }
    