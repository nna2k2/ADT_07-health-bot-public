
      .content {
        padding-bottom: 78px;
      }

      .head {
        display: grid;
        gap: 4px;
        margin-bottom: 12px;
      }

      .hero {
        border-radius: 28px;
        padding: 16px;
        color: #fff;
        box-shadow: 0px 16px 36px rgba(22, 163, 74, 0.22);
        background: linear-gradient(151.3deg, #00a63e 0%, #00bc7d 100%);
        margin-bottom: 14px;
      }

      .hero__title {
        font-size: 13px;
        opacity: 0.8;
        margin-bottom: 4px;
      }

      .hero__big {
        font-size: 24px;
        font-weight: 700;
        line-height: 36px;
        margin-bottom: 12px;
      }

      .chips {
        display: flex;
        gap: 12px;
      }

      .chip {
        flex: 1;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(4px);
        padding: 12px;
        text-align: center;
      }

      .chip__k {
        font-size: 10.8px;
        opacity: 0.85;
      }

      .chip__v {
        font-size: 14.8px;
        font-weight: 600;
        margin-top: 6px;
      }

      .form {
        display: grid;
        gap: 14px;
      }

      .grid2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }

      .control {
        width: 100%;
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 8px;
        padding: 10px 12px;
        outline: none;
        background: #fff;
      }

      .control:focus {
        border-color: rgba(32, 163, 41, 0.9);
        box-shadow: 0 0 0 3px rgba(32, 163, 41, 0.15);
      }

      .row {
        margin-top: 8px;
      }

      .ok {
        color: #007a55;
        font-size: 12px;
      }

      .api-error {
        color: #ec003f;
        font-size: 12px;
      }
    