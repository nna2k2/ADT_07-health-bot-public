
      .row {
        display: flex;
        gap: 8px;
        align-items: flex-start;
        justify-content: flex-start;
      }
      .row--user {
        justify-content: flex-end;
      }
      .avatar {
        width: 24px;
        height: 24px;
        display: grid;
        place-items: center;
        color: #000;
        opacity: 0.92;
      }
      .bubble {
        display: inline-block;
        width: fit-content;
        max-width: 340px;
        padding: 10px;
        border-radius: 12px;
        font-size: 14px;
        line-height: 1.4;
        background: transparent;
        color: #000;
      }
      .bubble--user {
        background: var(--primary);
        color: #fff;
      }

      .sev-wrap {
        margin-bottom: 8px;
      }

      .sev {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 4px 10px;
        font-size: 12px;
        font-weight: 700;
        line-height: 1.2;
        border: 1px solid rgba(0, 0, 0, 0.08);
        background: rgba(0, 0, 0, 0.03);
        color: rgba(0, 0, 0, 0.78);
      }

      .sev.sev--low {
        background: rgba(0, 166, 62, 0.12);
        border-color: rgba(0, 166, 62, 0.28);
        color: #007a55;
      }

      .sev.sev--medium {
        background: rgba(234, 179, 8, 0.14);
        border-color: rgba(234, 179, 8, 0.35);
        color: #92400e;
      }

      .sev.sev--high {
        background: rgba(234, 88, 12, 0.14);
        border-color: rgba(234, 88, 12, 0.35);
        color: #9a3412;
      }

      .sev.sev--emergency {
        background: rgba(220, 38, 38, 0.14);
        border-color: rgba(220, 38, 38, 0.35);
        color: #b91c1c;
      }

      :host ::ng-deep .md p {
        margin: 0 !important;
      }

      :host ::ng-deep .md p + p {
        margin-top: 8px !important;
      }

      :host ::ng-deep .md ul {
        margin: 8px 0 0 !important;
        padding-left: 18px !important;
      }

      :host ::ng-deep .md li {
        margin: 4px 0 !important;
      }

      :host ::ng-deep .md h3 {
        font-size: 14px;
        margin: 0 0 6px !important;
      }

      .cta {
        display: inline-block;
        margin-top: 10px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(0, 166, 62, 0.14);
        border: 1px solid rgba(0, 166, 62, 0.35);
        color: #008a34;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        line-height: 1.2;
      }

      .cta:hover {
        background: rgba(0, 166, 62, 0.22);
      }
    