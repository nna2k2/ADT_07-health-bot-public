
      .content {
        padding-bottom: 78px;
      }

      .head {
        display: grid;
        gap: 4px;
        margin-bottom: 12px;
      }

      .hero {
        border-radius: 28px;
        padding: 16px;
        color: #fff;
        box-shadow: 0px 16px 36px rgba(22, 163, 74, 0.22);
        background: linear-gradient(151.3deg, #00a63e 0%, #00bc7d 100%);
        margin-bottom: 14px;
      }

      .hero__title {
        font-size: 13px;
        opacity: 0.8;
        margin-bottom: 4px;
      }

      .hero__big {
        font-size: 24px;
        font-weight: 700;
        line-height: 36px;
        margin-bottom: 12px;
      }

      .chips {
        display: flex;
        gap: 12px;
      }

      .chip {
        flex: 1;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(4px);
        padding: 12px;
        text-align: center;
      }

      .chip__k {
        font-size: 10.8px;
        opacity: 0.85;
      }

      .chip__v {
        font-size: 14.8px;
        font-weight: 600;
        margin-top: 6px;
      }

      .meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 12px;
      }

      .meta__pill {
        background: #ecfdf5;
        color: #007a55;
        border-radius: 999px;
        padding: 6px 10px;
        font-size: 12px;
        font-weight: 600;
      }

      .text {
        white-space: pre-wrap;
        font-size: 13px;
        line-height: 1.5;
      }

      .stats-pre {
        margin-bottom: 10px;
        color: #171717;
      }

      .hint {
        margin-top: 0;
      }

      .err {
        color: #ec003f;
      }
    