
    .reminders-page {
      display: flex;
      flex-direction: column;
      height: 100%;
      background-color: #f4f4f4;
    }
    .top {
      padding: 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .top__title { font-size: 18px; font-weight: 600; line-height: 28px; color: #171717; }
    .top__sub { font-size: 12px; line-height: 16px; color: #737373; }
    .btn-new {
      border: none;
      border-radius: 999px;
      padding: 8px 12px;
      background: #00a63e;
      color: #fff;
      font-size: 12px;
      line-height: 16px;
      cursor: pointer;
      white-space: nowrap;
    }

    .content-body {
      padding: 16px;
      overflow-y: auto;
      flex: 1;
    }

    .empty-state { text-align: center; color: #9ca3af; font-size: 14px; padding: 20px 0; }

    .item {
      background: #fff;
      border-radius: 24px;
      padding: 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      box-shadow: 0px 1px 3px rgba(0,0,0,0.1), 0px 1px 2px -1px rgba(0,0,0,0.1);
      margin-bottom: 12px;
    }

    .item__main {
      border: none;
      background: transparent;
      padding: 0;
      text-align: left;
      display: grid;
      gap: 4px;
      cursor: pointer;
      flex: 1;
      min-width: 0;
    }

    .item__title { font-size: 14px; font-weight: 600; line-height: 20px; color: #171717; }
    .item__sub { font-size: 12px; line-height: 16px; color: #737373; }

    .toggle { position: relative; display: inline-flex; align-items: center; }
    .toggle input { opacity: 0; width: 0; height: 0; }
    .toggle__track {
      width: 48px; height: 28px; border-radius: 999px; background: #e5e5e5;
      padding: 4px; display: flex; justify-content: flex-start; transition: 0.2s;
    }
    .toggle__thumb { width: 20px; height: 20px; border-radius: 999px; background: #fff; }
    .toggle input:checked + .toggle__track { background: #00a63e; justify-content: flex-end; }
  