
      .content {
        padding-bottom: 24px;
      }

      .head {
        display: grid;
        gap: 6px;
        margin-bottom: 14px;
      }

      .sub {
        font-size: 12px;
        line-height: 16px;
      }

      .form {
        display: grid;
        gap: 12px;
      }

      .card {
        background: #fff;
        border-radius: var(--radius-24);
        padding: 14px 16px;
        box-shadow: var(--shadow-card);
        border: 1px solid rgba(0, 0, 0, 0.04);
      }

      .row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .grid2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }

      .label {
        font-size: 12px;
        line-height: 16px;
        margin-bottom: 6px;
      }

      .input {
        width: 100%;
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 12px;
        padding: 10px 12px;
        outline: none;
        background: #fff;
      }

      .input--small {
        width: 110px;
      }

      .input:focus {
        border-color: rgba(0, 166, 62, 0.55);
        box-shadow: 0 0 0 3px rgba(0, 166, 62, 0.14);
      }

      .hint {
        font-size: 12px;
        line-height: 16px;
        white-space: nowrap;
      }

      .btn {
        width: 100%;
        height: 52px;
        border: none;
        border-radius: 999px;
        background: var(--primary-2);
        color: #fff;
        font-size: 14px;
        font-weight: 600;
        line-height: 20px;
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(0, 166, 62, 0.28);
      }

      .btn:disabled {
        opacity: 0.75;
        cursor: not-allowed;
        box-shadow: none;
      }

      .err {
        color: #ec003f;
        font-size: 13px;
        margin-top: 8px;
      }
    