
      .vh {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .content {
        padding-bottom: 78px;
      }

      .page-head {
        margin-bottom: 16px;
      }

      .page-head__title {
        margin: 0;
        font-size: 22px;
        font-weight: 700;
        line-height: 26px;
        letter-spacing: -0.02em;
        color: var(--text);
      }

      .page-head__sub {
        margin: 6px 0 0;
        font-size: 13px;
        line-height: 18px;
      }

      .identity-wrap {
        margin-bottom: 22px;
      }

      .identity-card {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 16px 18px;
        background: #fff;
        border-radius: var(--radius-24);
        box-shadow: var(--shadow-card);
        border: 1px solid rgba(0, 0, 0, 0.04);
      }

      .identity-card__avatar {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        flex-shrink: 0;
        display: grid;
        place-items: center;
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(145deg, #20a329 0%, #00a63e 100%);
        box-shadow: 0 4px 14px rgba(0, 166, 62, 0.28);
      }

      .identity-card__body {
        flex: 1;
        min-width: 0;
      }

      .identity-card__eyebrow {
        font-size: 11px;
        line-height: 14px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }

      .identity-card__name {
        font-size: 17px;
        font-weight: 700;
        line-height: 22px;
        color: var(--text);
        margin-top: 2px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .identity-card__meta {
        font-size: 12px;
        line-height: 16px;
        margin-top: 2px;
      }

      .identity-card__icon {
        width: 36px;
        height: 36px;
        flex-shrink: 0;
        opacity: 0.22;
      }

      .err {
        color: #ec003f;
        font-size: 13px;
        margin: 0 0 12px;
      }

      .link-card {
        position: relative;
        display: block;
        background: #fff;
        border-radius: var(--radius-24);
        padding: 16px;
        box-shadow: var(--shadow-card);
        border: 1px solid rgba(0, 0, 0, 0.04);
        margin-bottom: 14px;
      }

      .link-card__t {
        font-size: 14px;
        font-weight: 700;
        line-height: 20px;
        color: var(--text);
      }

      .link-card__s {
        margin-top: 4px;
        font-size: 12px;
        line-height: 16px;
      }

      .link-card__chev {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 24px;
        color: var(--text);
        opacity: 0.85;
      }

      .footer-card {
        background: #fff;
        border-radius: var(--radius-24);
        padding: 16px;
        box-shadow: var(--shadow-card);
        border: 1px solid rgba(0, 0, 0, 0.04);
      }

      .footer-card__row {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
        padding: 6px 0;
        font-size: 13px;
      }

      .footer-card__k {
        flex-shrink: 0;
      }

      .footer-card__v {
        font-weight: 600;
        text-align: right;
        word-break: break-all;
      }

      .footer-card__v--mono {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 11px;
        font-weight: 500;
        color: var(--muted);
      }

      .footer-card__btn {
        width: 100%;
        margin-top: 12px;
        height: 46px;
        border: none;
        border-radius: var(--radius-16);
        background: var(--primary);
        color: #fff;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
      }

      .footer-card__btn:active {
        opacity: 0.9;
      }

      .footer-card__note {
        margin-top: 14px;
        padding-top: 14px;
        border-top: 1px solid rgba(0, 0, 0, 0.06);
        font-size: 12px;
        line-height: 17px;
      }

      .footer-card__note-t {
        display: block;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 4px;
      }
    