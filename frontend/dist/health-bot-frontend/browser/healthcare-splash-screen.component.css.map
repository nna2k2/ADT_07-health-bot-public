
      .splash {
        background: var(--bg);
      }

      /* Background image placement approximates Figma: x=-142, y=-20, w=672, h=864 */
      .splash__bg {
        position: absolute;
        left: -142px;
        top: -20px;
        width: 672px;
        height: 864px;
        background-image: url('/assets/splash-bg.png');
        background-size: cover;
        background-position: 50% 30%;
        background-repeat: no-repeat;
      }

      /* Figma: blur blob behind CTA card (Rectangle 834 blur 50) */
      .splash__blur {
        position: absolute;
        left: 32px;
        top: 571px;
        width: 326px;
        height: 288px;
        background: rgba(246, 246, 246, 1);
        filter: blur(50px);
      }

      /* Glass card: white 84% + shadow */
      .splash__card {
        position: absolute;
        left: 50%;
        top: 536px;
        transform: translateX(-50%);
        width: 355px;
        max-width: calc(100% - 32px);
        height: 279px;
        padding: 12px;
        border-radius: var(--radius-24);
        background: rgba(255, 255, 255, 0.84);
        box-shadow: var(--shadow-modal);
        backdrop-filter: blur(10px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
      }

      .splash__title {
        width: 291px;
        max-width: 100%;
      }

      .splash__title p {
        margin: 0;
      }

      .splash__desc {
        width: 291px;
        max-width: 100%;
        padding-bottom: 12px;
      }

      .splash__cta {
        width: 326px;
        max-width: 100%;
      }

      @media (max-width: 360px) {
        .splash__card {
          width: calc(100% - 24px);
        }
      }
    