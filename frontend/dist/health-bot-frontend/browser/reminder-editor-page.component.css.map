
      .content {
        min-height: 100%;
        background: #f4f4f4;
        padding-top: 8px;
        padding-bottom: 24px;
      }

      .form {
        display: grid;
        gap: 12px;
      }

      .card {
        background: #fff;
        border-radius: 16px;
        padding: 16px;
        box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.1), 0px 1px 2px -1px rgba(0, 0, 0, 0.1);
      }

      .input {
        width: 100%;
        border: none;
        outline: none;
        font-size: 14px;
        line-height: 20px;
        color: #171717;
      }

      .row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .row__label {
        font-size: 14px;
        line-height: 20px;
        color: #171717;
      }

      .row__value {
        font-size: 14px;
        line-height: 20px;
        color: #737373;
      }

      .row--disabled {
        opacity: 0.9;
      }

      .time {
        border: none;
        outline: none;
        font-size: 14px;
        line-height: 20px;
        color: #737373;
        background: transparent;
      }

      .type {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 8px;
      }

      .type__btn {
        border: 1px solid #e5e7eb;
        background: #fff;
        border-radius: 16px;
        padding: 12px 14px;
        font-size: 14px;
        line-height: 20px;
        color: #171717;
        cursor: pointer;
        box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.06), 0px 1px 2px -1px rgba(0, 0, 0, 0.06);
      }

      .type__btn--active {
        border-color: rgba(0, 166, 62, 0.35);
        box-shadow: 0 0 0 2px rgba(0, 166, 62, 0.12);
      }

      .repeat {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
      }

      .repeat__btn {
        border: 1px solid #e5e7eb;
        background: #fff;
        border-radius: 16px;
        padding: 12px 14px;
        font-size: 14px;
        line-height: 20px;
        color: #171717;
        cursor: pointer;
        box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.06), 0px 1px 2px -1px rgba(0, 0, 0, 0.06);
      }

      .repeat__btn--active {
        border-color: rgba(0, 166, 62, 0.35);
        box-shadow: 0 0 0 2px rgba(0, 166, 62, 0.12);
      }

      .btn {
        height: 52px;
        border: none;
        border-radius: 999px;
        background: #00a63e;
        color: #fff;
        font-size: 14px;
        font-weight: 600;
        line-height: 20px;
        cursor: pointer;
      }

      .btn:disabled {
        opacity: 0.75;
        cursor: not-allowed;
      }
    