
      :host {
        flex: 1;
        min-height: 0;
        display: flex;
        flex-direction: column;
      }

      .screen {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
      }

      .content {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding-bottom: 78px;
        min-height: 0;
      }

      .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 3px 12px;
      }

      .hello {
        font-size: 13.8px;
        line-height: 20px;
      }

      .name {
        font-size: 22px;
        font-weight: 600;
        line-height: 24px;
      }

      .notif {
        width: 56px;
        height: 56px;
        border-radius: 999px;
        background: #fff;
        box-shadow: var(--shadow-fab);
        display: grid;
        place-items: center;
        position: relative;
        border: none;
        cursor: pointer;
        padding: 0;
      }

      .notif__icon {
        width: 24px;
        height: 24px;
        display: block;
      }

      .badge {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 16px;
        height: 16px;
        background: #20a329;
        color: #fff;
        border-radius: 999px;
        display: grid;
        place-items: center;
        font-size: 10px;
        font-weight: 600;
      }

      .hero {
        width: 100%;
        background: var(--primary);
        border-radius: var(--radius-32);
        padding: 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: #fff;
        margin-bottom: 14px;
        gap: 8px;
        text-decoration: none;
        box-shadow: var(--shadow-card);
      }

      .hero__circle {
        width: 49.669px;
        height: 46px;
        border-radius: 999px;
        position: relative;
        overflow: hidden;
        flex-shrink: 0;
      }

      .hero__circle-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .hero__circle-icon {
        position: absolute;
        left: 10.8px;
        top: 12px;
        width: 26.994px;
        height: 22px;
        object-fit: cover;
      }

      .hero__arrow-wrap {
        position: absolute;
        left: 13.47px;
        top: 12.38px;
        width: 22.924px;
        height: 21.231px;
        display: grid;
        place-items: center;
        transform: rotate(90deg) scaleY(-1);
      }

      .hero__arrow {
        width: 22.924px;
        height: 21.231px;
        display: block;
      }

      .hero__text {
        font-size: 16px;
        font-weight: 600;
        line-height: 24px;
        width: 210px;
      }

      .panel {
        background: #fff;
        border-radius: var(--radius-24);
        padding: 14px 12px 16px;
        box-shadow: var(--shadow-card);
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .panel__title {
        font-size: 16px;
        font-weight: 600;
        line-height: 20px;
        padding: 0 4px;
        color: var(--text);
      }

      .panel__title--sub {
        font-size: 14px;
        margin-top: 2px;
      }

      .panel__divider {
        height: 1px;
        margin: 2px 4px;
        background: rgba(0, 0, 0, 0.06);
      }

      .grid {
        width: 100%;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
      }

      .tile {
        background: #f6f6f6;
        border-radius: 12px;
        padding: 12px 8px;
        height: 89px;
        display: grid;
        align-content: start;
        justify-items: center;
        gap: 4px;
        text-align: center;
        text-decoration: none;
        color: inherit;
        transition: background 0.15s ease;
      }

      .tile:active {
        background: #efefef;
      }

      .tile__icon {
        width: 18px;
        height: 18px;
        display: block;
      }

      .tile__text {
        font-size: 10px;
        font-weight: 700;
        line-height: 15px;
        color: var(--text);
      }

      .book-doctor {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        width: 100%;
        min-height: 52px;
        padding: 14px 20px;
        border-radius: var(--radius-20);
        background: var(--primary-2);
        color: #fff;
        font-size: 15px;
        font-weight: 600;
        line-height: 20px;
        text-decoration: none;
        box-shadow: 0 2px 8px rgba(0, 166, 62, 0.28);
      }

      .book-doctor__icon {
        width: 22px;
        height: 22px;
        flex-shrink: 0;
        filter: brightness(0) invert(1);
        opacity: 0.95;
      }

      .book-doctor:active {
        opacity: 0.92;
      }

      .tip {
        margin-top: auto;
        padding: 20px 12px 8px;
        text-align: center;
        font-size: 12px;
        line-height: 18px;
        max-width: 300px;
        margin-left: auto;
        margin-right: auto;
      }

      .tip strong {
        font-weight: 600;
        color: var(--text);
      }
    