
      .btn {
        height: 62px;
        border: 0;
        border-radius: 50px;
        background: var(--primary);
        color: var(--white);
        font-size: 24px;
        font-weight: 500;
        line-height: 18px;
        padding: 0 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        cursor: pointer;
        user-select: none;
      }

      .btn--full {
        width: 100%;
      }

      .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }
    