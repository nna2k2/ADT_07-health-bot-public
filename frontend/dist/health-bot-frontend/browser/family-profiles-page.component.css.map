
      .content {
        padding-bottom: 78px;
      }

      .head {
        display: grid;
        gap: 6px;
        margin-bottom: 14px;
      }

      .head__row {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
      }

      .title {
        font-size: 18px;
        font-weight: 600;
        line-height: 28px;
        color: var(--text);
      }

      .sub {
        font-size: 12px;
        line-height: 16px;
      }

      .btn-add {
        border: none;
        border-radius: 999px;
        padding: 8px 12px;
        background: var(--primary-2);
        color: #fff;
        font-size: 12px;
        line-height: 16px;
        cursor: pointer;
        white-space: nowrap;
        height: 32px;
        margin-top: 4px;
      }

      .list {
        display: grid;
        gap: 12px;
        padding-top: 12px;
      }

      .err {
        color: #ec003f;
        font-size: 13px;
        margin: 0 0 12px;
      }

      .card {
        width: 100%;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px;
        border-radius: var(--radius-24);
        background: var(--white);
        box-shadow: var(--shadow-card);
        border: 0;
        cursor: pointer;
        text-align: left;
      }

      .avatar {
        width: 48px;
        height: 48px;
        border-radius: 999px;
        flex-shrink: 0;
      }

      .body {
        flex: 1;
        min-width: 0;
        display: grid;
        gap: 4px;
      }

      .name {
        font-size: 14px;
        font-weight: 600;
        line-height: 20px;
        color: var(--text);
      }

      .meta {
        font-size: 12px;
        line-height: 16px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .chev {
        font-size: 24px;
        line-height: 24px;
        color: var(--text);
        opacity: 0.9;
        flex-shrink: 0;
      }
    