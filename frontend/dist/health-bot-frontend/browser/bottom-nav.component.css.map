
      .nav {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: 62px;
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        background: var(--white);
        border-top: 1px solid rgba(0, 0, 0, 0.06);
      }
      .nav__item {
        display: grid;
        place-items: center;
        font-size: 12px;
        color: #6c7278;
      }
      .nav__item.is-active {
        color: var(--primary);
        font-weight: 600;
      }
    