
      .header {
        margin-bottom: 12px;
        display: grid;
        gap: 4px;
      }

      .form {
        display: grid;
        gap: 14px;
      }

      .grid2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }

      .control {
        width: 100%;
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 8px;
        padding: 10px 12px;
        outline: none;
        background: #fff;
      }

      .control:focus {
        border-color: rgba(32, 163, 41, 0.9);
        box-shadow: 0 0 0 3px rgba(32, 163, 41, 0.15);
      }

      .row {
        margin-top: 8px;
      }

      .api-error {
        color: #ec003f;
        font-size: 12px;
      }
    